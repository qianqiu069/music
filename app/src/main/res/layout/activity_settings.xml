<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgGray">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/neteaseRed"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/btn_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/settings_title"
            android:textColor="@color/textOnDark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <TextView
                style="@style/SettingsGroupHeader"
                android:text="@string/settings_group_play" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bgWhite">

                <!-- 音质 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="@string/settings_quality"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp" />

                <RadioGroup
                    android:id="@+id/rg_quality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp">

                    <RadioButton
                        android:id="@+id/rb_standard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quality_standard"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_high"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quality_high"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_lossless"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quality_lossless"
                        android:textColor="@color/textPrimary"
                        android:textSize="14sp" />
                </RadioGroup>

                <View style="@style/ProfileDivider" />

                <!-- 仅 WiFi 下播放 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_wifi_only"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_wifi_only"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- 第 2 组：外观 -->
            <TextView
                style="@style/SettingsGroupHeader"
                android:text="@string/settings_group_look" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bgWhite">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_dark_mode"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_dark_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- 第 3 组：存储 -->
            <TextView
                style="@style/SettingsGroupHeader"
                android:text="@string/settings_group_storage" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bgWhite">

                <LinearLayout
                    android:id="@+id/row_clear_cache"
                    style="@style/ProfileRow">

                    <TextView
                        style="@style/ProfileRowText"
                        android:text="@string/settings_clear_cache" />

                    <TextView
                        android:id="@+id/tv_cache_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp" />

                    <TextView
                        style="@style/ProfileRowArrow"
                        android:text="@string/arrow_right" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
