<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml - 应用清单文件
  作用：声明应用包含哪些 Activity、要哪些权限、应用名/图标/主题等
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限：调用第三方 API 必须声明 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 检查网络状态权限：用于判断是否有网络 -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/app"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app"
        android:supportsRtl="true"
        android:theme="@style/Theme.MusicApp"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!--
          注意两个重要属性：
          1) usesCleartextTraffic="true" -> 允许 http:// 明文流量
             因为 API 是 http://cyapi.top，不是 https://，Android 9+ 默认禁止
          2) networkSecurityConfig -> 进一步配置网络安全策略
        -->

        <!-- 登录页：声明为启动页 (LAUNCHER)，使用启动画面专用主题展示 qd.png -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.MusicApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 歌单推荐页：登录成功后的新首页 -->
        <activity
            android:name=".PlaylistActivity"
            android:exported="false" />

        <!-- 搜索页（从歌单页右上角放大镜进入） -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- 播放页：使用深色专用主题，让状态栏与背景统一 -->
        <activity
            android:name=".PlayActivity"
            android:exported="false"
            android:theme="@style/Theme.MusicApp.Play" />

        <!-- ========== 新增 11 个页面 ========== -->
        <!-- 注册页 -->
        <activity android:name=".RegisterActivity" android:exported="false" />
        <!-- 找回密码 -->
        <activity android:name=".ForgotPasswordActivity" android:exported="false" />
        <!-- 个人中心 -->
        <activity android:name=".ProfileActivity" android:exported="false" />
        <!-- 歌单详情 -->
        <activity android:name=".PlaylistDetailActivity" android:exported="false" />
        <!-- 歌手详情 -->
        <activity android:name=".ArtistActivity" android:exported="false" />
        <!-- 专辑详情 -->
        <activity android:name=".AlbumActivity" android:exported="false" />
        <!-- 排行榜 -->
        <activity android:name=".RankActivity" android:exported="false" />
        <!-- 我喜欢的 -->
        <activity android:name=".FavoritesActivity" android:exported="false" />
        <!-- 播放历史 -->
        <activity android:name=".HistoryActivity" android:exported="false" />
        <!-- 设置 -->
        <activity android:name=".SettingsActivity" android:exported="false" />
        <!-- 关于 -->
        <activity android:name=".AboutActivity" android:exported="false" />

    </application>

</manifest>
